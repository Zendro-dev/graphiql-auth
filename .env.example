PORT="7070"
# This app's own public origin - defaults to "http://localhost:<PORT>" if
# unset, so changing PORT alone is enough for local use. Only set this
# explicitly when that default is wrong (different host/protocol, e.g.
# behind a reverse proxy). Must be registered as a redirect URI
# (<ORIGIN>/auth/callback) on the zendro_graphiql Keycloak client.
# ORIGIN="http://localhost:7070"

# The graphql-server this GraphiQL deployment talks to (required) - /graphql
# and /meta_query are both derived from this one origin.
ZENDRO_SERVER_URL="http://localhost:3000"
# Enables the jq/JSONPath filter panel (POSTs to <ZENDRO_SERVER_URL>/meta_query).
GRAPHIQL_FILTER_ENABLED="true"

# OAuth2 login (Keycloak client "zendro_graphiql" - see graphql-server's
# utils/setup-keycloak.js, KEYCLOAK_GIQL_CLIENT). This app is a confidential
# client: OAUTH2_CLIENT_SECRET must never be exposed to the browser.
OAUTH2_CLIENT_ID="zendro_graphiql"
OAUTH2_CLIENT_SECRET=""
# The realm's OIDC issuer - endpoints (authorization/token/end-session) are
# discovered from "<OAUTH2_ISSUER_URI>/.well-known/openid-configuration".
OAUTH2_ISSUER_URI="http://zendro-keycloak:8080/auth/realms/zendro"
# Signs the session/OAuth-flow cookies (HMAC secret) - set to a long random
# value, e.g. `openssl rand -hex 32`. Never reused across deployments.
SESSION_SECRET=""

POST_REQUEST_MAX_BODY_SIZE="1mb"
