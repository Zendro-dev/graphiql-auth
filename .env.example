PORT="7070"

# The graphql-server this GraphiQL deployment talks to (required).
ZENDRO_GRAPHQL_URL="http://localhost:3000/graphql"
# Enables the jq/JSONPath filter panel when set.
ZENDRO_METAQUERY_URL="http://localhost:3000/meta_query"

# OAuth2 login (Keycloak client "zendro_graphiql" - see graphql-server's
# utils/setup-keycloak.js, KEYCLOAK_GIQL_CLIENT). This app is a confidential
# client: OAUTH2_GRAPHIQL_CLIENT_SECRET must never be exposed to the browser.
OAUTH2_GRAPHIQL_CLIENT_ID="zendro_graphiql"
OAUTH2_GRAPHIQL_CLIENT_SECRET=""
OAUTH2_AUTHORIZATION_URI="http://zendro-keycloak:8080/auth/realms/zendro/protocol/openid-connect/auth"
OAUTH2_TOKEN_URI="http://zendro-keycloak:8080/auth/realms/zendro/protocol/openid-connect/token"
OAUTH2_LOGOUT_URI="http://zendro-keycloak:8080/auth/realms/zendro/protocol/openid-connect/logout"
# Must exactly match this app's own origin + /auth/callback, and be
# registered as a redirect URI on the zendro_graphiql Keycloak client.
OAUTH2_REDIRECT_URI="http://localhost:7070/auth/callback"
# Signs the session/OAuth-flow cookies (HMAC secret) - set to a long random
# value, e.g. `openssl rand -hex 32`. Never reused across deployments.
SESSION_SECRET=""

POST_REQUEST_MAX_BODY_SIZE="1mb"
